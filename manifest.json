{
  "manifest_version": 3,
  "name": "Booking Price Breakdown",
  "version": "1.0",
  "description": "Desglosa el precio total en precio por persona, por noche, etc.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.jpg"
  },
  "icons": {
    "128": "icon.jpg"
  },
  "content_scripts": [
    {
      "matches": ["https://*.booking.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
